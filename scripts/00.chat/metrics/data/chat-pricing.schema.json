{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chat pricing profile store",
  "type": "object",
  "required": ["schema_version", "default_profile", "currency", "unit", "profiles"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "default_profile": {
      "type": "string",
      "minLength": 1
    },
    "currency": {
      "type": "string",
      "minLength": 1
    },
    "unit": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": true
    },
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["model", "tier", "context", "estimate_rate_usd_per_1m_tokens", "assumption"],
        "properties": {
          "provider": {
            "type": "string"
          },
          "model": {
            "type": "string",
            "minLength": 1
          },
          "tier": {
            "type": "string",
            "minLength": 1
          },
          "context": {
            "type": "string",
            "minLength": 1
          },
          "estimate_rate_usd_per_1m_tokens": {
            "type": ["number", "null"],
            "minimum": 0
          },
          "assumption": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
